ALPHA_VANTAGE_API_KEY=
NEWSAPI_API_KEY=
NEWS_API_KEY=
PRICE_DATA_PROVIDER=auto
DATA_SOURCE_PREFERENCE=nsefin
ENABLE_CORPORATE_ACTIONS_ADJUSTMENT=true
NSE_BHAVCOPY_CACHE_HOURS=6
NSE_FUNDAMENTALS_REFRESH_DAYS=90
MIN_INVESTABLE_TURNOVER_RS=100000000
MIN_DELIVERY_PCT=40
MIN_VOLUME_CONSISTENCY_RATIO=0.8
SMALLCAP_INDEX_SYMBOL=^CNXSC
FULL_NSE_SCAN_LIMIT=all
FULL_NSE_SCAN_MAX=3000
SCAN_WORKERS=8
FULL_NSE_SCAN_DEEP_MODE=false
FULL_SCAN_REQUIRE_SECRET=false
ENABLE_DAILY_FULL_SCAN=false
AUTO_EOD_DB_SYNC=true
BHAVCOPY_RETENTION_DATES=2
BHAVCOPY_MAX_AGE_DAYS=2
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
ENABLE_WEEKLY_SCAN=false
WEEKLY_SCAN_LIMIT=35
REDIS_URL=
REDIS_TICK_CHANNEL=market:ticks
REDIS_TICK_HASH=market:latest_ticks
SHOONYA_IN_APP_FEED=true
