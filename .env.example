ALPHA_VANTAGE_API_KEY=
NEWSAPI_API_KEY=
NEWS_API_KEY=
PRICE_DATA_PROVIDER=auto
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
ENABLE_WEEKLY_SCAN=false
WEEKLY_SCAN_LIMIT=35
REDIS_URL=
REDIS_TICK_CHANNEL=market:ticks
REDIS_TICK_HASH=market:latest_ticks
SHOONYA_IN_APP_FEED=true
FEED_SYMBOLS=NIFTY,RELIANCE,HDFCBANK,POLYCAB,KPITTECH,DIXON,TATAPOWER,SUZLON
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
UNIVERSE_CACHE_PATH=
ACCOUNT_SIZE=1000000
MAX_SECTOR_EXPOSURE=0.25
MAX_PORTFOLIO_CORRELATION=0.65
CAUTION_PORTFOLIO_CORRELATION=0.40

# Optional PostgreSQL persistence. Leave blank to use the in-memory NSE cache.
DATABASE_URL=
ADMIN_SECRET=

# Optional symbol overrides when a provider uses a non-standard ticker format.
# Example:
# ALPHA_VANTAGE_SYMBOL_POLYCAB=POLYCAB.BSE
ALPHA_VANTAGE_SYMBOL_POLYCAB=

# Optional Shoonya live market feed. Keep these backend-only.
# Add them in Render Environment Variables, never in frontend files.
LIVE_DATA_PROVIDER=shoonya
BROKER_MODE=market_data_only
ENABLE_TRADING=false
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_TWOFA=
SHOONYA_TOTP_SECRET=
SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=
SHOONYA_IMEI=
